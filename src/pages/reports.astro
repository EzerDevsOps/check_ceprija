---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Reportes de Asistencia - CEPRIJA">
    <main class="min-h-screen bg-gray-50 text-gray-800">
        <div class="max-w-7xl mx-auto p-6">
            <!-- Header -->
            <header
                class="flex flex-col sm:flex-row items-center justify-between mb-8"
            >
                <div class="flex items-center gap-4 mb-4 sm:mb-0">
                    <div
                        class="bg-[#1e3a8a] text-white p-3 rounded-full w-14 h-14 flex items-center justify-center shadow-lg"
                    >
                        <span class="text-xl font-bold">C</span>
                    </div>
                    <div>
                        <h1 class="text-2xl font-bold text-[#1e3a8a]">
                            CEPRIJA
                        </h1>
                        <p class="text-sm text-[#fbbf24] font-semibold">
                            Reportes de Asistencia
                        </p>
                    </div>
                </div>
                <a
                    href="/"
                    class="bg-[#1e3a8a] text-white px-5 py-2 rounded-lg hover:bg-[#1e3a8a]/90 transition-colors font-medium shadow-md"
                >
                    ← Regresar al Escáner
                </a>
            </header>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- SECTION 1: DAILY REPORT -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <h2 class="text-xl font-bold text-[#1e3a8a] mb-4">
                📅 Reporte Diario
            </h2>

            <!-- Date Selector -->
            <div
                class="bg-white rounded-xl shadow-lg p-6 mb-6 border-t-4 border-[#1e3a8a]"
            >
                <div class="flex flex-col sm:flex-row items-center gap-4">
                    <label class="text-lg font-semibold text-gray-700"
                        >Seleccionar Fecha:</label
                    >
                    <select
                        id="day-select"
                        class="border-2 border-gray-300 rounded-lg px-4 py-2 text-lg focus:border-[#1e3a8a] focus:outline-none transition-colors min-w-[200px]"
                    >
                        <option value="">Cargando fechas...</option>
                    </select>
                    <button
                        id="download-btn"
                        class="bg-[#fbbf24] text-[#1e3a8a] px-5 py-2 rounded-lg hover:bg-[#fbbf24]/80 transition-colors font-bold shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
                        disabled
                    >
                        ⬇ Descargar CSV
                    </button>
                </div>
            </div>

            <div
                id="loading-daily"
                class="hidden bg-white rounded-xl shadow-lg p-12 text-center"
            >
                <div
                    class="animate-spin w-12 h-12 border-4 border-[#1e3a8a] border-t-transparent rounded-full mx-auto mb-4"
                >
                </div>
                <p class="text-gray-500">Cargando registros...</p>
            </div>
            <div
                id="empty-daily"
                class="hidden bg-white rounded-xl shadow-lg p-12 text-center mb-10"
            >
                <p class="text-gray-400 text-xl">
                    No hay registros para esta fecha
                </p>
            </div>

            <!-- Daily Results Table -->
            <div id="results-container" class="hidden mb-12">
                <div
                    class="bg-white rounded-xl shadow-lg overflow-hidden border-t-4 border-[#fbbf24]"
                >
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="bg-[#1e3a8a] text-white">
                                    <th
                                        class="px-4 py-4 text-left text-xs font-semibold uppercase tracking-wider"
                                        >No. Empleado</th
                                    >
                                    <th
                                        class="px-4 py-4 text-left text-xs font-semibold uppercase tracking-wider"
                                        >Nombre</th
                                    >
                                    <th
                                        class="px-4 py-4 text-left text-xs font-semibold uppercase tracking-wider"
                                        >Departamento</th
                                    >
                                    <th
                                        class="px-4 py-4 text-left text-xs font-semibold uppercase tracking-wider"
                                        >Asistencia</th
                                    >
                                    <th
                                        class="px-4 py-4 text-left text-xs font-semibold uppercase tracking-wider"
                                        >Registros</th
                                    >
                                    <th
                                        class="px-4 py-4 text-left text-xs font-semibold uppercase tracking-wider"
                                        >Horas</th
                                    >
                                </tr>
                            </thead>
                            <tbody id="daily-table-body"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- SECTION 2: MONTHLY REPORT -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <h2 class="text-xl font-bold text-[#1e3a8a] mb-4">
                📊 Reporte Mensual
            </h2>

            <div
                class="bg-white rounded-xl shadow-lg p-6 mb-6 border-t-4 border-[#1e3a8a]"
            >
                <div class="flex flex-col sm:flex-row items-center gap-4">
                    <label class="text-lg font-semibold text-gray-700"
                        >Seleccionar Mes:</label
                    >
                    <select
                        id="month-select"
                        class="border-2 border-gray-300 rounded-lg px-4 py-2 text-lg focus:border-[#1e3a8a] focus:outline-none transition-colors min-w-[200px]"
                    >
                        <option value="">Cargando meses...</option>
                    </select>
                    <button
                        id="download-monthly-btn"
                        class="bg-[#fbbf24] text-[#1e3a8a] px-5 py-2 rounded-lg hover:bg-[#fbbf24]/80 transition-colors font-bold shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
                        disabled
                    >
                        ⬇ Descargar CSV Mensual
                    </button>
                </div>
            </div>

            <div
                id="loading-monthly"
                class="hidden bg-white rounded-xl shadow-lg p-12 text-center"
            >
                <div
                    class="animate-spin w-12 h-12 border-4 border-[#1e3a8a] border-t-transparent rounded-full mx-auto mb-4"
                >
                </div>
                <p class="text-gray-500">Calculando reporte mensual...</p>
            </div>
            <div
                id="empty-monthly"
                class="hidden bg-white rounded-xl shadow-lg p-12 text-center"
            >
                <p class="text-gray-400 text-xl">No hay datos para este mes</p>
            </div>

            <!-- Monthly Results Table -->
            <div id="monthly-container" class="hidden">
                <div
                    id="monthly-meta"
                    class="text-sm text-gray-500 mb-2 text-right"
                >
                </div>
                <div
                    class="bg-white rounded-xl shadow-lg overflow-hidden border-t-4 border-[#1e3a8a]"
                >
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="bg-[#1e3a8a] text-white">
                                    <th
                                        class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider"
                                        >No. Empleado</th
                                    >
                                    <th
                                        class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider"
                                        >Nombre</th
                                    >
                                    <th
                                        class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider"
                                        >Departamento</th
                                    >
                                    <th
                                        class="px-6 py-4 text-center text-xs font-semibold uppercase tracking-wider"
                                        >✅ Asistencias</th
                                    >
                                    <th
                                        class="px-6 py-4 text-center text-xs font-semibold uppercase tracking-wider"
                                        >⏱ Retrasos</th
                                    >
                                    <th
                                        class="px-6 py-4 text-center text-xs font-semibold uppercase tracking-wider"
                                        >🚫 Ausencias</th
                                    >
                                </tr>
                            </thead>
                            <tbody id="monthly-table-body"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        // ────── helpers ──────
        function statusBadge(s: string): string {
            if (s === "PUNTUAL")
                return `<span class="inline-block bg-green-100 text-green-800 border border-green-300 rounded-full px-2 py-0.5 text-xs font-bold">✔ PUNTUAL</span>`;
            if (s === "RETRASO")
                return `<span class="inline-block bg-yellow-100 text-yellow-800 border border-yellow-300 rounded-full px-2 py-0.5 text-xs font-bold">⚠ RETRASO</span>`;
            if (s === "AUSENCIA")
                return `<span class="inline-block bg-red-100 text-red-800 border border-red-300 rounded-full px-2 py-0.5 text-xs font-bold">✘ AUSENCIA</span>`;
            return "";
        }

        function punchBadge(r: any): string {
            const bg =
                r.status === "ENTRADA"
                    ? "bg-green-100 text-green-800 border-green-300"
                    : "bg-orange-100 text-orange-800 border-orange-300";
            return `<span class="inline-block ${bg} border rounded-full px-2 py-0.5 text-xs font-semibold mr-1 mb-1">${r.status} ${r.time}</span>`;
        }

        // ────── DAILY ──────
        const daySelect = document.getElementById(
            "day-select",
        ) as HTMLSelectElement;
        const downloadBtn = document.getElementById(
            "download-btn",
        ) as HTMLButtonElement;
        const loadingDaily = document.getElementById("loading-daily")!;
        const emptyDaily = document.getElementById("empty-daily")!;
        const resultsContainer = document.getElementById("results-container")!;
        const dailyTableBody = document.getElementById("daily-table-body")!;

        async function loadDays() {
            try {
                const res = await fetch("/api/days");
                const data = await res.json();
                daySelect.innerHTML = "";

                if (data.days?.length) {
                    data.days.forEach((day: string) => {
                        const opt = document.createElement("option");
                        opt.value = day;
                        const [y, m, d] = day.split("-");
                        opt.textContent = `${d}/${m}/${y}`;
                        daySelect.appendChild(opt);
                    });
                    loadAttendance(data.days[0]);
                } else {
                    daySelect.innerHTML =
                        '<option value="">No hay registros disponibles</option>';
                }
            } catch (e) {
                console.error(e);
            }
        }

        async function loadAttendance(date: string) {
            if (!date) return;
            loadingDaily.classList.remove("hidden");
            emptyDaily.classList.add("hidden");
            resultsContainer.classList.add("hidden");
            downloadBtn.disabled = false;

            try {
                const res = await fetch(`/api/attendance?date=${date}`);
                const data = await res.json();
                loadingDaily.classList.add("hidden");

                if (!data.employees || !Object.keys(data.employees).length) {
                    emptyDaily.classList.remove("hidden");
                    return;
                }

                dailyTableBody.innerHTML = "";
                let idx = 0;
                for (const [empId, emp] of Object.entries(data.employees) as [
                    string,
                    any,
                ][]) {
                    // Determine primary attendance status (first ENTRADA)
                    const firstEntrada = emp.records.find(
                        (r: any) => r.status === "ENTRADA",
                    );
                    const primaryStatus = firstEntrada?.attendanceStatus ?? "-";

                    const row = document.createElement("tr");
                    row.className = idx++ % 2 === 0 ? "bg-white" : "bg-gray-50";
                    row.innerHTML = `
                        <td class="px-4 py-3 font-mono text-sm font-bold text-[#1e3a8a]">${empId}</td>
                        <td class="px-4 py-3 font-medium">${emp.name}</td>
                        <td class="px-4 py-3 text-gray-600 text-sm">${emp.department}</td>
                        <td class="px-4 py-3">${statusBadge(primaryStatus)}</td>
                        <td class="px-4 py-3">${emp.records.map(punchBadge).join("")}</td>
                        <td class="px-4 py-3 text-sm">
                            <span class="inline-block bg-blue-100 text-blue-800 border border-blue-300 rounded-full px-3 py-1 text-xs font-semibold">🕐 ${emp.totalHours}</span>
                        </td>`;
                    dailyTableBody.appendChild(row);
                }
                resultsContainer.classList.remove("hidden");
            } catch (e) {
                loadingDaily.classList.add("hidden");
                emptyDaily.classList.remove("hidden");
            }
        }

        daySelect.addEventListener("change", () =>
            loadAttendance(daySelect.value),
        );
        downloadBtn.addEventListener("click", () => {
            if (daySelect.value)
                window.location.href = `/api/download?date=${daySelect.value}`;
        });

        // ────── MONTHLY ──────
        const monthSelect = document.getElementById(
            "month-select",
        ) as HTMLSelectElement;
        const downloadMonthlyBtn = document.getElementById(
            "download-monthly-btn",
        ) as HTMLButtonElement;
        const loadingMonthly = document.getElementById("loading-monthly")!;
        const emptyMonthly = document.getElementById("empty-monthly")!;
        const monthlyContainer = document.getElementById("monthly-container")!;
        const monthlyTableBody = document.getElementById("monthly-table-body")!;
        const monthlyMeta = document.getElementById("monthly-meta")!;

        async function loadMonths() {
            try {
                const res = await fetch("/api/days");
                const data = await res.json();
                if (!data.days?.length) {
                    monthSelect.innerHTML =
                        '<option value="">No hay datos disponibles</option>';
                    return;
                }
                // Extract unique YYYY-MM strings from actual daily CSV dates
                const months = [
                    ...new Set<string>(
                        data.days.map((d: string) => d.substring(0, 7)),
                    ),
                ]
                    .sort()
                    .reverse();

                monthSelect.innerHTML = "";
                months.forEach((m) => {
                    const opt = document.createElement("option");
                    opt.value = m;
                    const [y, mo] = m.split("-");
                    const monthName = new Date(
                        parseInt(y),
                        parseInt(mo) - 1,
                        1,
                    ).toLocaleString("es-MX", {
                        month: "long",
                        year: "numeric",
                    });
                    opt.textContent =
                        monthName.charAt(0).toUpperCase() + monthName.slice(1);
                    monthSelect.appendChild(opt);
                });
                loadMonthly(months[0]);
            } catch (e) {
                console.error(e);
            }
        }

        async function loadMonthly(month: string) {
            if (!month) return;
            loadingMonthly.classList.remove("hidden");
            emptyMonthly.classList.add("hidden");
            monthlyContainer.classList.add("hidden");
            downloadMonthlyBtn.disabled = true;

            try {
                const res = await fetch(`/api/monthly?month=${month}`);
                const data = await res.json();
                loadingMonthly.classList.add("hidden");

                if (!data.report?.length || data.daysAnalyzed === 0) {
                    emptyMonthly.classList.remove("hidden");
                    return;
                }

                downloadMonthlyBtn.disabled = false;

                monthlyTableBody.innerHTML = "";
                monthlyMeta.textContent = `Días analizados: ${data.daysAnalyzed} | Archivo generado: monthly_reports/monthly_${month}.csv`;

                data.report.forEach((emp: any, i: number) => {
                    const row = document.createElement("tr");
                    row.className = i % 2 === 0 ? "bg-white" : "bg-gray-50";
                    const attendColor =
                        emp.attendances > 0
                            ? "bg-green-100 text-green-800 border-green-300"
                            : "bg-gray-100 text-gray-600 border-gray-200";
                    const delayColor =
                        emp.delays > 0
                            ? "bg-yellow-100 text-yellow-800 border-yellow-300"
                            : "bg-gray-100 text-gray-600 border-gray-200";
                    const absenceColor =
                        emp.absences > 0
                            ? "bg-red-100 text-red-800 border-red-300"
                            : "bg-gray-100 text-gray-600 border-gray-200";
                    row.innerHTML = `
                        <td class="px-6 py-4 font-mono text-sm font-bold text-[#1e3a8a]">${emp.id}</td>
                        <td class="px-6 py-4 font-medium">${emp.name}</td>
                        <td class="px-6 py-4 text-gray-600 text-sm">${emp.department}</td>
                        <td class="px-6 py-4 text-center">
                            <span class="inline-block ${attendColor} border rounded-full px-4 py-1 text-sm font-bold">${emp.attendances}</span>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class="inline-block ${delayColor} border rounded-full px-4 py-1 text-sm font-bold">${emp.delays}</span>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class="inline-block ${absenceColor} border rounded-full px-4 py-1 text-sm font-bold">${emp.absences}</span>
                        </td>`;
                    monthlyTableBody.appendChild(row);
                });
                monthlyContainer.classList.remove("hidden");
            } catch (e) {
                loadingMonthly.classList.add("hidden");
                emptyMonthly.classList.remove("hidden");
            }
        }

        monthSelect.addEventListener("change", () =>
            loadMonthly(monthSelect.value),
        );
        downloadMonthlyBtn.addEventListener("click", () => {
            if (monthSelect.value)
                window.location.href = `/api/download-monthly?month=${monthSelect.value}`;
        });

        // Init
        loadDays();
        loadMonths();
    </script>
</Layout>
